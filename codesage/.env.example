# CodeSage Environment Configuration
# Copy this file to .env and fill in your values.

# ── LLM Configuration ─────────────────────────────────────────────────────────
# Google Gemini API Key (required for all agent operations)
GOOGLE_API_KEY=your_google_api_key_here

# Primary and fallback models for agent LLM calls
MODEL_PRIMARY=gemini-1.5-pro-latest
MODEL_FALLBACK=gemini-1.5-flash-latest

# ── Infrastructure ─────────────────────────────────────────────────────────────
# Qdrant vector store
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=codesage_chunks

# SQLite paths
SQLITE_PATH=./codesage.db

# ── Test Configuration ─────────────────────────────────────────────────────────
# Timeout for test execution (seconds)
TEST_TIMEOUT_SECONDS=60
